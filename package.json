{
  "name": "ecobairro",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "scripts": {
    "lint": "pnpm -r --if-present run lint",
    "typecheck": "pnpm -r --if-present run typecheck",
    "compose:config": "docker compose -f infra/compose/docker-compose.yml config",
    "compose:up": "docker compose -f infra/compose/docker-compose.yml up --build"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/node": "^22.13.10",
    "eslint": "^9.22.0",
    "globals": "^16.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  }
}

