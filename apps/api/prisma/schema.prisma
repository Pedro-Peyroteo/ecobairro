// ─────────────────────────────────────────────────────────────────────────────
// QUIZZES
// ─────────────────────────────────────────────────────────────────────────────

model Quiz {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo          String    @db.VarChar(200)
  descricao       String?
  tipo            TipoQuiz
  disponivelDe    DateTime  @map("disponivel_de") @db.Timestamptz
  disponivelAte   DateTime  @map("disponivel_ate") @db.Timestamptz
  numeroPerguntas Int       @map("numero_perguntas") @db.SmallInt
  pontosMaximo    Int       @default(0) @map("pontos_maximo")
  categoriaTema   String?   @map("categoria_tema") @db.VarChar(50)
  ativo           Boolean   @default(true)
  criadoPor       String?   @map("criado_por") @db.Uuid
  criadoEm        DateTime  @default(now()) @map("criado_em") @db.Timestamptz

  criadoPorUser User?          @relation(fields: [criadoPor], references: [id])
  perguntas     QuizPergunta[]
  sessoes       QuizSessao[]

  @@map("quizzes")
}

model QuizPergunta {
  id                  String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  quizId              String    @map("quiz_id") @db.Uuid
  ordem               Int       @db.SmallInt
  textoPergunta       String    @map("texto_pergunta")
  explicacaoEducativa String    @map("explicacao_educativa")
  pontos              Int       @default(10) @db.SmallInt
  imagemUrl           String?   @map("imagem_url") @db.VarChar(500)
  criadoEm            DateTime  @default(now()) @map("criado_em") @db.Timestamptz

  quiz   Quiz        @relation(fields: [quizId], references: [id], onDelete: Cascade)
  opcoes QuizOpcao[]

  @@unique([quizId, ordem])
  @@map("quiz_perguntas")
}

model QuizOpcao {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  perguntaId String   @map("pergunta_id") @db.Uuid
  ordem      Int      @db.SmallInt
  texto      String
  correta    Boolean  @default(false)
  criadoEm   DateTime @default(now()) @map("criado_em") @db.Timestamptz

  pergunta QuizPergunta @relation(fields: [perguntaId], references: [id], onDelete: Cascade)

  @@unique([perguntaId, ordem])
  @@map("quiz_opcoes")
}

model QuizSessao {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  cidadaoId      String    @map("cidadao_id") @db.Uuid
  quizId         String    @map("quiz_id") @db.Uuid
  tipo           TipoQuiz
  respostas      Json?
  scoreObtido    Int?      @map("score_obtido")
  totalPerguntas Int?      @map("total_perguntas") @db.SmallInt
  concluidoEm    DateTime? @map("concluido_em") @db.Timestamptz

  cidadao User @relation(fields: [cidadaoId], references: [id])
  quiz    Quiz @relation(fields: [quizId], references: [id])

  @@map("quiz_sessoes")
}

// ─────────────────────────────────────────────────────────────────────────────
// REPORTS
// ─────────────────────────────────────────────────────────────────────────────

model Report {
  id                  String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  numero              BigInt          @unique @default(autoincrement())
  cidadaoId           String          @map("cidadao_id") @db.Uuid
  ecopontoId          String?         @map("ecoponto_id") @db.Uuid
  zonaId              String          @map("zona_id") @db.Uuid
  categoria           CategoriaReport
  descricao           String?
  localizacao         Unsupported("geography(Point, 4326)")
  localizacaoManual   Boolean         @default(false) @map("localizacao_manual")
  fotoUrl             String?         @map("foto_url") @db.VarChar(500)
  fotoThumbnailUrl    String?         @map("foto_thumbnail_url") @db.VarChar(500)
  estado              EstadoReport    @default(RECEBIDO)
  motivoRejeicao      String?         @map("motivo_rejeicao")
  entidadeResponsavel String?         @map("entidade_responsavel") @db.VarChar(50)
  atribuidoA          String?         @map("atribuido_a") @db.Uuid
  atribuidoEm         DateTime?       @map("atribuido_em") @db.Timestamptz
  reportPaiId         String?         @map("report_pai_id") @db.Uuid
  primeiraRespostaEm  DateTime?       @map("primeira_resposta_em") @db.Timestamptz
  resolvidoEm         DateTime?       @map("resolvido_em") @db.Timestamptz
  numSubscricoes      Int             @default(0) @map("num_subscricoes")
  criadoEm            DateTime        @default(now()) @map("criado_em") @db.Timestamptz
  atualizadoEm        DateTime        @updatedAt @map("atualizado_em") @db.Timestamptz
  eliminadoEm         DateTime?       @map("eliminado_em") @db.Timestamptz

  cidadao           User               @relation("ReportCidadao", fields: [cidadaoId], references: [id])
  ecoponto          Ecoponto?          @relation(fields: [ecopontoId], references: [id])
  zona              Zona               @relation(fields: [zonaId], references: [id])
  atribuidoAUser    User?              @relation("ReportAtribuido", fields: [atribuidoA], references: [id])
  reportPai         Report?            @relation("ReportDuplicado", fields: [reportPaiId], references: [id])
  reportsDuplicados Report[]           @relation("ReportDuplicado")
  timeline          ReportTimeline[]
  subscricoes       ReportSubscricao[]

  @@map("reports")
}

model ReportTimeline {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  reportId       String    @map("report_id") @db.Uuid
  estadoAnterior String?   @map("estado_anterior") @db.VarChar(20)
  estadoNovo     String    @map("estado_novo") @db.VarChar(20)
  nota           String?
  alteradoPor    String?   @map("alterado_por") @db.Uuid
  alteradoEm     DateTime  @default(now()) @map("alterado_em") @db.Timestamptz

  report          Report @relation(fields: [reportId], references: [id])
  alteradoPorUser User?  @relation(fields: [alteradoPor], references: [id])

  @@map("reports_timeline")
}

model ReportSubscricao {
  reportId  String   @map("report_id") @db.Uuid
  cidadaoId String   @map("cidadao_id") @db.Uuid
  criadoEm  DateTime @default(now()) @map("criado_em") @db.Timestamptz

  report  Report @relation(fields: [reportId], references: [id])
  cidadao User   @relation(fields: [cidadaoId], references: [id])

  @@id([reportId, cidadaoId])
  @@map("reports_subscricoes")
}

