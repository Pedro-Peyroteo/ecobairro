// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CIDADAO
  OPERADOR_VEOLIA
  TECNICO_AUTARQUIA
  TECNICO_CCDR
  ADMIN
}

enum ReportStatus {
  PENDENTE
  ANALISE
  RESOLVIDO
  REJEITADO
}

model User {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email         String         @unique
  passwordHash  String         @map("password_hash")
  phone         String?
  emailVerified Boolean        @default(false) @map("email_verified")
  role          UserRole
  criadoEm      DateTime       @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm  DateTime       @updatedAt @map("atualizado_em") @db.Timestamptz(6)
  eliminadoEm   DateTime?      @map("eliminado_em") @db.Timestamptz(6)

  cidadaoPerfil CidadaoPerfil?
  reports       Report[]
  partilhas     Partilha[]

  @@index([role])
  @@map("users")
}

model CidadaoPerfil {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String   @unique @map("user_id") @db.Uuid
  nomeCompleto      String?  @map("nome_completo")
  gamificationOptIn Boolean  @default(false) @map("gamification_opt_in")
  notificacaoPrefs  Json?    @map("notificacao_prefs")
  dashboardWidgets  Json?    @map("dashboard_widgets")
  rgpdAccepted      Boolean  @map("rgpd_accepted")
  criadoEm          DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm      DateTime @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("cidadao_perfis")
}

model Report {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo      String
  tipo        String
  descricao   String
  local       String
  imagemUrl   String?      @map("imagem_url")
  status      ReportStatus @default(PENDENTE)
  userId      String       @map("user_id") @db.Uuid
  criadoEm    DateTime     @default(now()) @map("criado_em") @db.Timestamptz(6)
  atualizadoEm DateTime    @updatedAt @map("atualizado_em") @db.Timestamptz(6)

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([criadoEm])
  @@index([userId])
  @@map("reports")
}

model Ecoponto {
  id                String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome              String
  codigo            String?
  morada            String   @default("")
  zona              String?
  distanciaLabel    String   @default("") @map("distancia_label")
  ocupacao          Int
  tipos             Json     @default("[]")
  sensorEstado      String   @default("online") @map("sensor_estado")
  ultimaRecolha     String?  @map("ultima_recolha")
  ultimaAtualizacao String?  @map("ultima_atualizacao")
  lat               Float    @default(40.6409)
  lng               Float    @default(-8.6537)
  mapTileUrl        String?  @map("map_tile_url")
  ordem             Int      @default(0)
  ativo             Boolean  @default(true)
  criadoEm          DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)

  @@map("ecopontos")
}

model Partilha {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo     String
  autorNome  String   @map("autor_nome")
  zona       String
  userId     String?  @map("user_id") @db.Uuid
  criadoEm   DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([criadoEm])
  @@map("partilhas")
}

model Noticia {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo           String
  resumo           String
  imagemUrl        String   @map("imagem_url")
  publishedAt      DateTime @map("published_at") @db.Timestamptz(6)
  tempoLeituraMin  Int      @default(3) @map("tempo_leitura_min")

  @@index([publishedAt])
  @@map("noticias")
}

model QuizDesafio {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  titulo          String
  bonusXp         Int      @map("bonus_xp")
  tempoLimiteMin  Int      @map("tempo_limite_min")
  ano             Int
  ativo           Boolean  @default(true)
  criadoEm        DateTime @default(now()) @map("criado_em") @db.Timestamptz(6)

  @@map("quiz_desafios")
}
