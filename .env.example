# --- PostgreSQL (Docker Compose) ------------------------------------------
# Used to build DATABASE_URL inside docker-compose.yml.
POSTGRES_DB=ecobairro
POSTGRES_USER=ecobairro
POSTGRES_PASSWORD=ecobairro
POSTGRES_PORT=5432

# --- DATABASE_URL (direct / Azure VM) -------------------------------------
# Required when running the API locally WITHOUT Docker Compose.
# For the Azure VM (4.231.93.80), open an SSH tunnel first:
#   ssh -i ecobairro_key.pem -L 5432:localhost:5432 azureuser@4.231.93.80
# Then set:
#   DATABASE_URL=postgresql://ecobairro:PASSWORD@localhost:5432/ecobairro?sslmode=disable
# In production with TLS (RNF-SEG-01):
#   DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/ecobairro?sslmode=require
DATABASE_URL=

# --- Redis ----------------------------------------------------------------
REDIS_URL=redis://localhost:6379/0

# --- Nginx ----------------------------------------------------------------
NGINX_PORT=8080

# --- Auth / JWT -----------------------------------------------------------
JWT_ACCESS_SECRET=dev-access-secret-change-me
JWT_ACCESS_TTL_MINUTES=15
REFRESH_TOKEN_TTL_DAYS=7
BCRYPT_ROUNDS=12

